		(uuid "4c020173-d37a-48e7-aa58-e9b8617b527a")
	)
	(text "V_{IN} = 6V - 8.4V (2S Li-Ion)\n\nP_{IN MAX} = P_{3.3V MAX} + P_{5V MAX}\n+ P_{SENSE MAX} + P_{PYRO CH MAX} =\n11.65W + 16.67W + 0.34W + 6.22W = 34.88W\n\nI_{IN MAX} = P_{IN MAX} / V_{IN MIN} =\n34.77W / 6V = 5.81A"
		(exclude_from_sim no)
		(at 13.97 50.8 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left top)
		)
		(uuid "573d8812-9fff-4970-a65d-54ac2ebbf445")
	)
	(text "V_{OUT} = ((R_{TOP} / R_{BOTTOM}) + 1) × 0.8V =\n((2MΩ / 383kΩ) +1) × 0.8V =\n4.98V\n\nP_{IN MAX} = P_{5V} / η_{5V @ 3A}) = \n((5V × 3A) / 0.9) =\n16.67W"
		(exclude_from_sim no)
		(at 162.56 96.52 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "7a9317c7-27da-495d-8d8f-7f64e3487a15")
	)
	(text "3.3V DC/DC Regulator"
		(exclude_from_sim no)
		(at 162.56 13.97 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "86f05c93-bb2f-4d01-995f-9e46bc9f1179")
	)
	(text "Pyrotechnic channel A,B,C,D"
		(exclude_from_sim no)
		(at 27.94 115.57 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "d16693a8-9ca0-4f6b-a254-3bc9c3c322b5")
	)
	(text "I_{LED} = (V_{IN} - V_{F}) / R =\n3.3V - 2.2V / 100Ω = 11mA"
		(exclude_from_sim no)
		(at 194.31 44.45 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "d5f530bd-0d84-4ab6-b139-01bc1ec7582f")
	)
	(text "V_{OUT} = ((R_{TOP} / R_{BOTTOM}) + 1) × 0.8V =\n((1.21MΩ / 383kΩ) +1) × 0.8V =\n3.33V\n\nP_{IN MAX} = (P_{3.3V} / η_{3.3V @ 3A}) =\n((3.3V × 3A) / 0.85) =\n11.65W"
		(exclude_from_sim no)
		(at 162.56 44.45 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "e60f6bb4-def8-45c5-bfb3-830d640ce47e")
	)
	(text "I_{SENSE MAX} = V_{MAX} / R_{TOT} =\n8.4V / (47kΩ + 10kΩ) = 0.15mA\n\nI_{SENSE MIN} = V_{MIN} / R_{TOT} =\n6V / (47kΩ + 10kΩ) = 0.10mA\n\nV_{SENSE MAX} = V_{MAX} × (R_{BOTTOM} / (R_{TOP} + R_{BOTTOM})) =\n8.4V × (10kΩ / (47kΩ+ 10kΩ)) = 1.47V\n\nV_{SENSE MIN} = V_{MIN} × (R_{BOTTOM} / (R_{TOP} + R_{BOTTOM})) =\n6V × (10kΩ / (47kΩ+ 10kΩ)) = 1.05V"
		(exclude_from_sim no)
		(at 53.34 166.37 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "f3265182-09d3-4fb8-82a2-db479e9977db")
	)

	(text "Power input protection & control"
		(exclude_from_sim no)
		(at 13.97 13.97 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "0c45e82c-5f47-40da-b2b2-7a45f506cd20")
	)
	(text "R_{LIMIT} = 10Ω\nt = 100ms\nI_{MAX CH} = V_{MAX} / R_{MIN} + R_{LIMIT} =\n8.4V / (1.2Ω + 10Ω) = 0.74A\n\nI_{MIN CH} = V_{MIN} / R_{MAX} + R_{LIMIT} =\n6V / (1.8Ω + 10Ω) = 0.51A\n\nP_{LIMIT MAX} = R_{LIMIT} × I_{MAX}^{2} =\n10Ω × 0.74A^{2} = 5.48W\n\nP_{PYRO CH MAX} = V_{MAX} × I_{MAX} =\n8.4V × 0.74A = 6.22W"
		(exclude_from_sim no)
		(at 27.94 166.37 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "0d9fdfa8-d869-4895-b076-4c669df3166e")
	)
	(text "V_{SENSE MAX} = 163.84mV\n\nR_{SHUNT MAX} = V_{sense max} / I_{max} =\n163.84mV / (34.54W / 6V) = 28.46mΩ = 10mΩ\n\nP_{max} = R_{shunt} × I_{max}^{2} =\n10mΩ × 5.79A^{2} = 0.34W"
		(exclude_from_sim no)
		(at 100.33 53.34 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "3463366e-b1c5-4125-88a5-2782ba11f81d")
	)
	(text "Pyrotechnic channels switch"
		(exclude_from_sim no)
		(at 153.67 72.39 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify right top)
		)
		(uuid "4391aea8-37c1-46e1-bf52-265653a92abb")
	)
	(text "I_{LED} = (V_{IN} - V_{F}) / R =\n3.3V - 2.2V / 100Ω = 11mA"

	(text "F = 25MHz\nESR = 40Ω\nC_{L} = 8pF\nC_{0} = 7pF\nC_{S} = 5pF\ng_{m} = 5 mA/V\nC_{tot} = C_{L} + (C_{S} / 2)\n\nC_{L1/2} = 2 × (C_{L} - C_{S}) = 6pF\nDL = (ESR × (π × F × C_{tot})^{2} × (V_{pp})^{2}) / 2 = 97.07μW\ng_{m critical} = 4 × (ESR) × (2 × π × F)^{2} × (C_{0} + C_{L})^{2} = 0.89 mA/V\ng_{m margin} = g_{m margin} / g_{m critical} = 5.63\n"
		(exclude_from_sim no)
		(at 13.97 171.45 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "ed2a4099-72f2-48bc-8d04-3573206fa7ea")
	)
